# ---------------------------------------------------------------------------
# PDB ID pattern: starts with digit, exactly 4 alphanumeric chars
# This matches real PDB IDs (1UBQ, 2M02, 7N4I) and rejects UUID/BMRB/NMR etc.
# ---------------------------------------------------------------------------
PDB_RE = re.compile(r'\b([0-9][A-Za-z0-9]{3})\b')

# Strings that look like PDB IDs but aren't
PDB_BLACKLIST = {
    'UUID', 'BMRB', 'NMR', 'CYSA', 'HTTP', 'HTML', 'JSON',
    'TRUE', 'NULL', 'NONE', 'N/A', 'YES', 'NO',
}


def is_valid_pdb_id(s: str) -> bool:
    s = s.upper().strip()
    if s in PDB_BLACKLIST:
        return False
    if not PDB_RE.match(s):
        return False
    if s.isdigit():
        return False
    return True


# ---------------------------------------------------------------------------
# Network helpers with caching
# ---------------------------------------------------------------------------

def get_json(url: str, cache_key: str) -> dict | None:
    cached = CACHE_DIR / f"{cache_key}.json"
    if cached.exists():
        try:
            return json.loads(cached.read_text())
        except Exception:
            pass
    try:
        time.sleep(REQUEST_DELAY)
        r = requests.get(url, timeout=30)
        if r.ok:
            data = r.json()
            cached.write_text(json.dumps(data))
            return data
    except Exception as e:
        pass
    return None


def get_text(url: str, cache_key: str) -> str | None:
    cached = CACHE_DIR / f"{cache_key}.txt"
    if cached.exists():
        t = cached.read_text(errors='replace')
        if t.strip():
            return t
    try:
        time.sleep(REQUEST_DELAY)
        r = requests.get(url, timeout=45)
        if r.ok and r.text.strip():
            cached.write_text(r.text)
            return r.text
    except Exception:
        pass
    return None


# ---------------------------------------------------------------------------
# Robust PDB ID extraction from BMRB entry
# Scans ALL saveframes and ALL loops — not just 3 hardcoded tags
# ---------------------------------------------------------------------------

def extract_pdb_ids_from_entry(entry) -> list[str]:
    """
    Scan entire BMRB entry for PDB cross-reference IDs.
    Returns list of candidate PDB IDs, best candidates first.
    """
    hits_explicit = []   # from database_2 loop — most reliable
    hits_general  = []   # from any other field

    for sf in entry.frame_list:
        # Method 1: Check _Database_2 loop (BMRB standard cross-reference)
        for loop in sf.loops:
            tags_lower = [t.lower() for t in loop.tags]
            
            # Look for database_2 style loops
            db_name_col  = next((i for i, t in enumerate(tags_lower)
                                 if 'database_name' in t or 'database_id' in t), None)
            db_code_col  = next((i for i, t in enumerate(tags_lower)
                                 if 'accession_code' in t or 'database_code' in t), None)
            
            if db_name_col is not None and db_code_col is not None:
                for row in loop.data:
                    try:
                        db_name = str(row[db_name_col]).upper()
                        db_code = str(row[db_code_col]).strip()
                        if 'PDB' in db_name and is_valid_pdb_id(db_code):
                            hits_explicit.append(db_code.upper())
                    except (IndexError, TypeError):
                        pass

        # Method 2: Scan all tag values in this saveframe
        for tag in sf.tags:
            try:
                vals = sf.get_tag(tag)
                for v in vals:
                    if isinstance(v, str):
                        for match in PDB_RE.findall(v):
                            if is_valid_pdb_id(match):
                                hits_general.append(match.upper())
            except Exception:
                pass

        # Method 3: Scan all loop cell values
        for loop in sf.loops:
            for row in loop.data:
                for cell in row:
                    if isinstance(cell, str) and len(cell) == 4:
                        if is_valid_pdb_id(cell):
                            hits_general.append(cell.upper())

    # Deduplicate, prefer explicit hits
    seen = set()
    result = []
    for h in hits_explicit + hits_general:
        if h not in seen:
            seen.add(h)
            result.append(h)

    return result


def extract_pdb_ids_from_api(api_data: dict) -> list[str]:
    """
    Extract PDB IDs from BMRB API JSON response.
    Handles nested structures properly.
    """
    hits = []
    api_str = json.dumps(api_data)
    
    # Look for explicit PDB database references
    # Common patterns: {"database": "PDB", "accession": "1UBQ"}
    #                  {"related_entries": [{"database_name": "PDB", "accession_code": "2M02"}]}
    try:
        # Recursive search for PDB-tagged accessions
        def search(obj, parent_key=""):
            if isinstance(obj, dict):
                has_pdb = any('pdb' in str(k).lower() or 
                             ('database' in str(k).lower() and 'PDB' in str(v).upper())
                             for k, v in obj.items())
                for k, v in obj.items():
                    if ('accession' in str(k).lower() or 'code' in str(k).lower()):
                        if isinstance(v, str) and is_valid_pdb_id(v):
                            hits.append(v.upper())
                    search(v, str(k))
            elif isinstance(obj, list):
                for item in obj:
                    search(item, parent_key)
        search(api_data)
    except Exception:
        pass

    # Fallback: regex on full JSON string, but filter strictly
    for match in PDB_RE.findall(api_str):
        if is_valid_pdb_id(match):
            hits.append(match.upper())

    # Deduplicate
    seen, result = set(), []
    for h in hits:
        if h not in seen:
            seen.add(h)
            result.append(h)
    return result


# ---------------------------------------------------------------------------
# BMRB entry parsing
# ---------------------------------------------------------------------------

def parse_bmrb_entry(bmrb_id: int) -> dict:
    result = {
        'bmrb_id': bmrb_id, 'n_residues': 0,
        'ca_count': 0, 'cb_count': 0, 'n_count': 0, 'ha_count': 0,
        'pdb_candidates': [], 'pdb_id': None, 'fetch_ok': False,
    }

    text = None
    for url in [
        f"https://bmrb.io/ftp/pub/bmrb/entry_directories/bmr{bmrb_id}/bmr{bmrb_id}_3.str",
        f"https://bmrb.io/ftp/pub/bmrb/entry_directories/bmr{bmrb_id}/bmr{bmrb_id}.str",
    ]:
        text = get_text(url, f"bmr{bmrb_id}")
        if text and text.strip().startswith("data_"):
            break
        text = None

    if not text:
        return result

    result['fetch_ok'] = True

    try:
        entry = pynmrstar.Entry.from_string(text)
    except Exception:
        return result

    # Count shifts
    seq_ids = set()
    atom_counts = {}
    for loop in entry.get_loops_by_category('Atom_chem_shift'):
        tags = loop.tags
        if 'Seq_ID' not in tags or 'Atom_ID' not in tags:
            continue
        si, ai = tags.index('Seq_ID'), tags.index('Atom_ID')
        for row in loop.data:
            try:
                seq_ids.add(int(row[si]))
                atom = str(row[ai]).strip().upper()
                atom_counts[atom] = atom_counts.get(atom, 0) + 1
            except Exception:
                pass

    result['n_residues'] = len(seq_ids)
    result['ca_count']   = atom_counts.get('CA', 0)
    result['cb_count']   = atom_counts.get('CB', 0)
    result['n_count']    = atom_counts.get('N', 0)
    result['ha_count']   = atom_counts.get('HA', 0)

    # Extract PDB candidates using robust method
    pdb_candidates = extract_pdb_ids_from_entry(entry)
    result['pdb_candidates'] = pdb_candidates
    result['pdb_id'] = pdb_candidates[0] if pdb_candidates else None

    return result


# ---------------------------------------------------------------------------
# PDB CIF parsing using BioPython's MMCIF2Dict for robustness
# ---------------------------------------------------------------------------

def parse_pdb_cif(pdb_id: str) -> dict:
    result = {
        'pdb_id': pdb_id, 'chain_a_residues': 0, 'n_chains': 0,
        'helix_segs': 0, 'sheet_segs': 0,
        'helix_residues': 0, 'strand_residues': 0, 'fetch_ok': False,
    }

    cif_text = get_text(
        f"https://files.rcsb.org/download/{pdb_id}.cif",
        f"pdb_{pdb_id}"
    )
    if not cif_text:
        return result

    result['fetch_ok'] = True

    # Try BioPython MMCIF2Dict first (handles quoted strings correctly)
    try:
        from Bio.PDB.MMCIF2Dict import MMCIF2Dict
        import tempfile, os
        with tempfile.NamedTemporaryFile(mode='w', suffix='.cif',
                                         delete=False, encoding='utf-8') as f:
            f.write(cif_text)
            tmp = f.name
        try:
            mmcif = MMCIF2Dict(tmp)
        finally:
            os.unlink(tmp)

        # Count residues per chain
        group_pdb  = mmcif.get('_atom_site.group_PDB', [])
        chain_ids  = mmcif.get('_atom_site.label_asym_id', [])
        seq_ids    = mmcif.get('_atom_site.label_seq_id', [])

        residues = set()
        for g, c, s in zip(group_pdb, chain_ids, seq_ids):
            if g == 'ATOM':
                try:
                    residues.add((c, int(s)))
                except ValueError:
                    pass

        chains = sorted(set(c for c, _ in residues))
        result['n_chains'] = len(chains)
        if chains:
            first = chains[0]
            result['chain_a_residues'] = len(set(s for c, s in residues if c == first))

        # Parse SS from _struct_conf (helices)
        conf_types  = mmcif.get('_struct_conf.conf_type_id', [])
        conf_starts = mmcif.get('_struct_conf.beg_label_seq_id', [])
        conf_ends   = mmcif.get('_struct_conf.end_label_seq_id', [])
        for t, s, e in zip(conf_types, conf_starts, conf_ends):
            if 'HELX' in t.upper():
                result['helix_segs'] += 1
                try:
                    result['helix_residues'] += int(e) - int(s) + 1
                except ValueError:
                    pass

        # Parse SS from _struct_sheet_range (strands)
        sheet_starts = mmcif.get('_struct_sheet_range.beg_label_seq_id', [])
        sheet_ends   = mmcif.get('_struct_sheet_range.end_label_seq_id', [])
        result['sheet_segs'] = len(sheet_starts)
        for s, e in zip(sheet_starts, sheet_ends):
            try:
                result['strand_residues'] += int(e) - int(s) + 1
            except ValueError:
                pass

        return result

    except Exception as bio_err:
        pass

    # Fallback to manual parsing if BioPython fails
    residues = set()
    atom_cols: list = []
    in_atom = False
    helix_ranges, sheet_ranges = [], []
    conf_cols, sheet_cols = [], []
    in_conf = in_sheet = False

    for line in cif_text.splitlines():
        s = line.strip()
        if s.startswith('_atom_site.'):
            atom_cols.append(s.split('.')[1].split()[0])
            in_atom = True; continue
        if in_atom:
            if s.startswith('_') or s.startswith('#') or s == 'loop_':
                in_atom = False; continue
            if not s: continue
            parts = s.split()
            ci = {c: i for i, c in enumerate(atom_cols)}
            try:
                if parts[ci.get('group_PDB', 0)] == 'ATOM':
                    residues.add((parts[ci['label_asym_id']], int(parts[ci['label_seq_id']])))
            except Exception:
                pass

        if s.startswith('_struct_conf.'):
            conf_cols.append(s.split('.')[1].split()[0]); in_conf=True; in_sheet=False; continue
        if s.startswith('_struct_sheet_range.'):
            sheet_cols.append(s.split('.')[1].split()[0]); in_sheet=True; in_conf=False; continue
        if s.startswith('_') or s == 'loop_': in_conf = in_sheet = False

        if in_conf and conf_cols and s and not s.startswith('_'):
            if 'HELX' in s.upper():
                result['helix_segs'] += 1
                ci = {c: i for i, c in enumerate(conf_cols)}
                try:
                    result['helix_residues'] += (int(s.split()[ci['end_label_seq_id']]) -
                                                  int(s.split()[ci['beg_label_seq_id']]) + 1)
                except Exception: pass
        if in_sheet and sheet_cols and s and not s.startswith('_'):
            p = s.split()
            if p and not p[0].startswith('_') and p[0] != 'loop_':
                result['sheet_segs'] += 1
                ci = {c: i for i, c in enumerate(sheet_cols)}
                try:
                    result['strand_residues'] += int(p[ci['end_label_seq_id']]) - int(p[ci['beg_label_seq_id']]) + 1
                except Exception: pass

    chains = sorted(set(c for c, _ in residues))
    result['n_chains'] = len(chains)
    if chains:
        result['chain_a_residues'] = len(set(s for c, s in residues if c == chains[0]))

    return result


# ---------------------------------------------------------------------------
# Scoring
# ---------------------------------------------------------------------------

def compute_score(row: dict) -> tuple[bool, str, float]:
    b_res = row['n_residues']
    ca, cb = row['ca_count'], row['cb_count']
    p_res = row['chain_a_residues']
    h_segs, s_segs = row['helix_segs'], row['sheet_segs']
    h_res = row['helix_residues']

    if not row['fetch_ok']:        return False, "BMRB fetch failed", 0.0
    if not row['pdb_fetch_ok']:    return False, "PDB fetch failed", 0.0
    if b_res == 0:                 return False, "no residues in BMRB", 0.0
    if p_res == 0:                 return False, "no residues in PDB", 0.0
    if ca < 15:                    return False, f"CA too low ({ca})", 0.0
    if cb < 8:                    return False, f"CB too low ({cb})", 0.0
    if h_segs + s_segs < 2:       return False, "no SS annotations in CIF", 0.0
    delta = abs(b_res - p_res)
    if delta > 15:                 return False, f"residue mismatch Δ={delta}", 0.0

    score = 0.0
    score += min(ca, 150) / 150 * 30
    score += min(cb, 150) / 150 * 30
    score += (1 - delta / 15) * 10
    score += min(h_segs, 5) * 3
    score += min(s_segs, 5) * 3
    h_frac = h_res / max(p_res, 1)
    if 0.15 < h_frac < 0.85:
        score += 10

    issues = []
    if delta > 5:   issues.append(f"Δ={delta}")
    if h_segs == 0: issues.append("no helix")
    if s_segs == 0: issues.append("no strand")

    return True, "; ".join(issues), round(score, 1)


