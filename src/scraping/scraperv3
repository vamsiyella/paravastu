def main():
    print("=" * 65)
    print("  BMRB SOLID-STATE SCRAPER (v2 — fixed PDB extraction)")
    print("=" * 65)

    # Diagnostic mode
    if DIAG_ID:
        print(f"\n[DIAG] Inspecting BMRB {DIAG_ID}")
        text = get_text(
            f"https://bmrb.io/ftp/pub/bmrb/entry_directories/bmr{DIAG_ID}/bmr{DIAG_ID}_3.str",
            f"bmr{DIAG_ID}"
        )
        if text:
            entry = pynmrstar.Entry.from_string(text)
            pdb_ids = extract_pdb_ids_from_entry(entry)
            print(f"  Found PDB candidates: {pdb_ids}")
        api = get_json(f"https://api.bmrb.io/v2/entry/{DIAG_ID}?format=json", f"api_{DIAG_ID}")
        if api:
            print(f"\n  API response (first 3000 chars):")
            print(json.dumps(api, indent=2)[:3000])
        sys.exit(0)

    bmrb_ids = get_solidstate_ids()
    bmrb_ids = [x for x in bmrb_ids if x not in SKIP]
    print(f"  Candidates: {len(bmrb_ids)}\n")

    rows = []
    n_pass = n_fail = n_no_pdb = 0

    for i, bmrb_id in enumerate(bmrb_ids):
        print(f"[{i+1:3d}/{len(bmrb_ids)}] BMRB {bmrb_id}", end="  ", flush=True)

        bmrb = parse_bmrb_entry(bmrb_id)
        if not bmrb['fetch_ok']:
            print("BMRB fetch failed")
            n_fail += 1
            continue

        ca, cb = bmrb['ca_count'], bmrb['cb_count']
        print(f"res={bmrb['n_residues']} CA={ca} CB={cb}", end="  ")

        if ca < 20 or cb < 10:
            print("→ skip (low CA/CB)")
            n_fail += 1
            continue

        # Try all PDB candidates until one validates
        pdb_candidates = bmrb['pdb_candidates']

        # Also try BMRB API if no candidates from .str
        if not pdb_candidates:
            api = get_json(f"https://api.bmrb.io/v2/entry/{bmrb_id}?format=json",
                           f"api_{bmrb_id}")
            if api:
                pdb_candidates = extract_pdb_ids_from_api(api)

        if not pdb_candidates:
            print("→ no PDB link")
            n_no_pdb += 1
            rows.append({**bmrb, 'pdb_id': None, 'chain_a_residues': 0,
                         'n_chains': 0, 'helix_segs': 0, 'sheet_segs': 0,
                         'helix_residues': 0, 'strand_residues': 0,
                         'pdb_fetch_ok': False, 'delta_res': 999,
                         'helix_pct': 0, 'strand_pct': 0,
                         'passes': False, 'fail_reason': 'no PDB link',
                         'score': 0, 'already_have': bmrb_id in ALREADY_HAVE,
                         'pdb_candidates_tried': []})
            continue

        print(f"PDB candidates: {pdb_candidates[:4]}", end="  ")

        # Try each candidate and keep the best match
        best_row = None
        best_score = -1

        for pdb_id in pdb_candidates[:5]:  # try up to 5 candidates
            pdb = parse_pdb_cif(pdb_id)
            if not pdb['fetch_ok']:
                continue
            delta = abs(bmrb['n_residues'] - pdb['chain_a_residues'])
            h_pct = round(100 * pdb['helix_residues'] / max(pdb['chain_a_residues'], 1), 1)
            s_pct = round(100 * pdb['strand_residues'] / max(pdb['chain_a_residues'], 1), 1)
            row = {**bmrb, 'pdb_id': pdb_id,
                   'chain_a_residues': pdb['chain_a_residues'],
                   'n_chains': pdb['n_chains'],
                   'helix_segs': pdb['helix_segs'],
                   'sheet_segs': pdb['sheet_segs'],
                   'helix_residues': pdb['helix_residues'],
                   'strand_residues': pdb['strand_residues'],
                   'pdb_fetch_ok': True,
                   'delta_res': delta, 'helix_pct': h_pct, 'strand_pct': s_pct,
                   'pdb_candidates_tried': pdb_candidates[:5]}
            passes, reason, score = compute_score(row)
            row.update({'passes': passes, 'fail_reason': reason, 'score': score,
                        'already_have': bmrb_id in ALREADY_HAVE})
            if score > best_score:
                best_score = score
                best_row = row

        if best_row is None:
            print("→ all PDB candidates failed CIF fetch")
            n_fail += 1
            rows.append({**bmrb, 'pdb_id': pdb_candidates[0] if pdb_candidates else None,
                         'chain_a_residues': 0, 'n_chains': 0, 'helix_segs': 0,
                         'sheet_segs': 0, 'helix_residues': 0, 'strand_residues': 0,
                         'pdb_fetch_ok': False, 'delta_res': 999, 'helix_pct': 0,
                         'strand_pct': 0, 'passes': False,
                         'fail_reason': 'all PDB CIF fetches failed',
                         'score': 0, 'already_have': bmrb_id in ALREADY_HAVE,
                         'pdb_candidates_tried': pdb_candidates[:5]})
            continue

        rows.append(best_row)
        if best_row['passes']:
            n_pass += 1
            flag = f"✓ PASS (score={best_score})"
        else:
            n_fail += 1
            flag = f"✗ {best_row['fail_reason']}"
        print(f"best={best_row['pdb_id']} Δ={best_row['delta_res']} H={best_row['helix_pct']}% → {flag}")

    # Save
    df = pd.DataFrame(rows)
    if not df.empty:
        df = df.sort_values(['passes', 'score'], ascending=[False, False]).reset_index(drop=True)
        df.to_csv(OUT_CSV, index=False)

    # Summary
    print(f"\n\n{'='*65}")
    print(f"  RESULTS")
