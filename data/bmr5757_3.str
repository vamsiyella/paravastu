   _Citation.Title                       'Evidence for a dimerisation state of the Bacillus subtilis catabolite repression HPr-like protein, Crh.'
   _Citation.Status                       published
   _Citation.Type                         journal
   _Citation.Journal_abbrev              'J. Mol. Microbiol. Biotechnol.'
   _Citation.Journal_name_full           'Journal of molecular microbiology and biotechnology'
   _Citation.Journal_volume               3
   _Citation.Journal_issue                3
   _Citation.Journal_ASTM                 .
   _Citation.Journal_ISSN                 1464-1801
